# ─── App ───────────────────────────────────────────────────────────────
# In production, set this to your actual domain (https://yourdomain.com).
# Used for Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for HMAC-signing the guest usage cookie.
# Generate: openssl rand -hex 32
COOKIE_SECRET=

# ─── Supabase ──────────────────────────────────────────────────────────
# Found in Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only. Bypasses RLS. Used by the Stripe webhook and convert route
# to record conversions regardless of the caller's auth state. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Stripe ────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys. Use test keys locally (sk_test_*).
STRIPE_SECRET_KEY=sk_test_...

# Dashboard → Developers → Webhooks → your endpoint → Signing secret.
# When running `stripe listen` locally, this is printed on start.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe → Products. Create one Product with two recurring
# prices: $9/month and $89/year. NEXT_PUBLIC so the pricing page can read
# them — they are safe to expose.
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_...
